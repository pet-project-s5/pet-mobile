# ─── Copie este arquivo para .env e preencha os valores ────────────────────────
# cp .env.example .env

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=petapi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_a_senha_aqui

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria

# ─── Groq Cloud (dicas de IA) ───────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx
