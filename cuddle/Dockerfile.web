FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci --legacy-peer-deps

COPY . .

# Chave Groq injetada como build arg (nunca via .env commitado)
ARG EXPO_PUBLIC_GROQ_API_KEY
ENV EXPO_PUBLIC_GROQ_API_KEY=$EXPO_PUBLIC_GROQ_API_KEY

# Gera a pasta dist/ com o build web do Expo
RUN npx expo export --platform web

# ── Servidor nginx ────────────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html

# Config SPA — redireciona tudo pro index.html
RUN printf 'server {\n\
  listen 8081;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  location / {\n\
    try_files $uri $uri/ /index.html;\n\
  }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 8081

CMD ["nginx", "-g", "daemon off;"]
